# paper2trace LLM provider: anthropic or openai
API_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model and generation defaults
MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_SFT_MAX_TOKENS=16384
LLM_DPO_MAX_TOKENS=16384

# paper2trace runtime defaults
PAPER2TRACE_OUTPUT_DIR=paper2trace/output
PAPER2TRACE_DOCUMENT_MAX_CHARS=28000
PAPER2TRACE_PAPER_ID_MAX_LENGTH=30
PAPER2TRACE_RANDOM_SEED=0

# Semantic quality sampling
SEMANTIC_INFERRED_SAMPLE_SIZE=3
SEMANTIC_SFT_SAMPLE_SIZE=4
SEMANTIC_DPO_SAMPLE_SIZE=3

# Rule-based quality thresholds
QUALITY_MIN_REJECTED_NODES=2
QUALITY_MIN_INFERRED_NODES=3
QUALITY_MIN_SFT_ITEMS=15
QUALITY_MIN_REACT_THOUGHTS=5
QUALITY_MIN_DPO_CHOSEN_CHARS=300
QUALITY_MIN_DPO_LENGTH_RATIO=0.45
